# =============================================
# TourismRAG 环境变量配置模板
# 复制此文件为 .env 并填写真实值
# =============================================

# ---- 阿里云 DashScope (Qwen) ----
DASHSCOPE_API_KEY=

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=tourism_root_2024
MYSQL_DATABASE=tourism_rag
MYSQL_USER=tourism
MYSQL_PASSWORD=tourism_pass_2024

# ---- Milvus ----
# Docker Compose 内服务用 milvus；本机 make run 时 Makefile 会强制 localhost
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_FAIL_FAST=true

# ---- 应用端口 ----
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ---- 宝塔生产部署 (backend/app.sh) ----
# JAVA_BIN=/www/server/java/jdk-21.0.2/bin/java
# JAVA_OPTS=-Xms1g -Xmx2g -XX:+UseG1GC

# =============================================
# 智能行程 Agent 配置
# =============================================

# 高德地图 API（POI / 路线 / 天气 / 美食）—— Web 服务 Key
MAP_API_KEY=

# 高德 JS API 2.0（前端行程地图：路网规划 / 标记 / 导航）
# 在高德控制台单独申请「Web端(JS API)」类型 Key，并配置安全密钥 securityJsCode
# 与 MAP_API_KEY 类型不同，不可混用
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# POI 数据源顺序（gaode,rag,xhs；xhs 需配置下方小红书密钥）
AGENT_POI_FALLBACK_ORDER=gaode,rag,xhs
# 美食数据源顺序（境外城市自动跳过高德，走 xhs+llm）
AGENT_FOOD_FALLBACK_ORDER=gaode,xhs,llm
AGENT_ACCOMMODATION_FALLBACK_ORDER=gaode,llm
ACCOMMODATION_MIN_RATING=3.8
AGENT_POI_RAG_ENABLED=true

# ---- 小红书攻略搜索（Cookie 模式，无需开放平台申请）----
# 1. 浏览器登录 xiaohongshu.com → F12 → Network → 任意请求 → 复制 Cookie 整段
# 2. pip install xhshow
# 3. 填写 XHS_COOKIE（必须用双引号包裹，否则分号会被 shell 截断）
XHS_ENABLED=false
XHS_MODE=cookie
XHS_COOKIE=""
# 可选：独立签名 HTTP 服务；留空则自动用 Python 子进程签名
# XHS_SIGN_URL=http://127.0.0.1:8765/sign
AGENT_POI_FALLBACK_ORDER=gaode,rag,xhs

AGENT_ENABLED=true
AGENT_TIMEOUT_MS=45000
AGENT_MAX_STEPS=10
FOOD_MIN_RATING=4.0

# =============================================
# 多智能体协作系统
# =============================================
MULTI_AGENT_ENABLED=true
MULTI_AGENT_STREAM_TIMEOUT=120000
MULTI_AGENT_DEBATE_ENABLED=true
